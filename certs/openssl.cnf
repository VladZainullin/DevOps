[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req

[dn]
C = CH
ST = Zurich
L = Zurich
O = Local Development
OU = Development
CN = ocr.vladislavzainullin.com

[v3_req]
subjectAltName = @alt_names
basicConstraints = critical, CA:FALSE
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = ocr.vladislavzainullin.com
DNS.2 = localhost
IP.1 = 127.0.0.1